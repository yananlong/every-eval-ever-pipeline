# DuckDB ingestion base directory (all jsonl_path values must resolve inside this)
INGESTION_BASE_DIR=data

# Supabase Postgres
DATABASE_URL=postgresql://postgres:password@localhost:5432/every_eval_ever

# Cloudflare R2 credentials
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_BUCKET_NAME=eval-bundles

# API authentication
API_KEY=your_api_key_here

# Worker settings
WORKER_POLL_INTERVAL_SECONDS=5
